# Copy this file to `.env` and fill in the keys for the providers you use.
# `.env` is gitignored — never commit real keys.
#
# Load it into your shell before running, e.g.:
#   set -a; source .env; set +a
#   ruby-llm-eval run --provider anthropic --model claude-sonnet-4-6

# Anthropic (provider: anthropic)
ANTHROPIC_API_KEY=

# OpenAI (provider: openai)
OPENAI_API_KEY=

# OpenAI-compatible gateways
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=

# Self-hosted OpenAI-compatible endpoints (Ollama/vLLM/LM Studio).
# Many local servers ignore the key, but the variable must exist — use any value.
LOCAL_API_KEY=not-needed
